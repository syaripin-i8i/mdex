{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/syaripin-i8i/mdex/schemas/scan.schema.json",
  "title": "mdex scan output",
  "description": "Contract for mdex scan JSON output",
  "type": "object",
  "required": [
    "nodes",
    "edges",
    "output"
  ],
  "properties": {
    "contract_schema": {
      "type": "string",
      "description": "Schema URL identifying this output contract. Optional in 0.2.x; expected on new CLI success payloads."
    },
    "contract_version": {
      "type": "string",
      "description": "mdex contract version for this payload. Optional in 0.2.x; expected on new CLI success payloads."
    },
    "nodes": {
      "type": "integer",
      "minimum": 0
    },
    "edges": {
      "type": "object",
      "required": [
        "total",
        "resolved",
        "unresolved",
        "resolution_rate"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "resolved": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved": {
          "type": "integer",
          "minimum": 0
        },
        "resolution_rate": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "output": {
      "type": "object",
      "required": [
        "json",
        "db"
      ],
      "properties": {
        "json": {
          "type": "string",
          "minLength": 1
        },
        "db": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "error"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
