{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/syaripin-i8i/mdex/schemas/context.schema.json",
  "title": "mdex context output",
  "description": "Contract for mdex context JSON output",
  "type": "object",
  "required": [
    "query",
    "nodes",
    "total_tokens",
    "budget"
  ],
  "properties": {
    "contract_schema": {
      "type": "string",
      "description": "Schema URL identifying this output contract. Optional in 0.2.x; expected on new CLI success payloads."
    },
    "contract_version": {
      "type": "string",
      "description": "mdex contract version for this payload. Optional in 0.2.x; expected on new CLI success payloads."
    },
    "query": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contextNode"
      }
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "budget": {
      "type": "integer",
      "minimum": 1
    },
    "recommended_read_order": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/readOrderItem"
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "deprecated": true,
      "description": "Deprecated v1 string actions kept for 0.2.x compatibility. Agents should prefer recommended_next_actions_v2 to avoid parsing command strings.",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_actions_v2": {
      "type": "array",
      "description": "Preferred structured actions for agents. Execute command and args as argv, not as a shell string.",
      "items": {
        "$ref": "#/$defs/actionV2Item"
      }
    },
    "deferred_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deferredItem"
      }
    },
    "confidence": {
      "type": "number"
    },
    "why_this_set": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actionable_digest": {
      "$ref": "#/$defs/actionableDigest"
    }
  },
  "$defs": {
    "actionableDigest": {
      "type": "object",
      "required": [
        "intent",
        "relevant_docs",
        "suggested_rg",
        "context_gaps"
      ],
      "properties": {
        "intent": {
          "type": "string"
        },
        "relevant_docs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digestNode"
          }
        },
        "relevant_task_history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digestNode"
          }
        },
        "likely_code_entrypoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digestNode"
          }
        },
        "known_guardrails": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digestNode"
          }
        },
        "suggested_rg": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rgSuggestion"
          }
        },
        "context_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "digestNode": {
      "type": "object",
      "required": [
        "id",
        "title",
        "type",
        "status",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "rgSuggestion": {
      "type": "object",
      "required": [
        "command",
        "args",
        "pattern",
        "paths",
        "reason"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pattern": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "readOrderItem": {
      "type": "object",
      "required": [
        "id",
        "title",
        "priority",
        "source",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "source": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "deferredItem": {
      "type": "object",
      "required": [
        "id",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "actionV2Item": {
      "type": "object",
      "required": [
        "command",
        "args",
        "reason"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "contextNode": {
      "type": "object",
      "required": [
        "id",
        "priority",
        "score",
        "score_breakdown",
        "estimated_tokens"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "score": {
          "type": "number"
        },
        "score_breakdown": {
          "type": "object"
        },
        "estimated_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "content": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
