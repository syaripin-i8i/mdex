{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/syaripin-i8i/mdex/schemas/error.schema.json",
  "title": "mdex stderr error payload",
  "description": "Contract for stderr JSON emitted by mdex commands on failure",
  "type": "object",
  "required": [
    "error"
  ],
  "properties": {
    "error": {
      "type": "string",
      "minLength": 1
    },
    "detail": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "resolution_attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "exists": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
